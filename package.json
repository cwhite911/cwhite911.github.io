{
  "name": "cwhite911.github.io",
  "private": true,
  "description": "A simplified bare-bones starter for Gatsby",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "build": "gatsby build",
    "develop": "gatsby develop -H 0.0.0.0",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1",
    "deploy": "gatsby build && gh-pages -d public",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "bootstrap": "^5.3.8",
    "gatsby": "^5.16.1",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-offline": "^6.16.0",
    "gatsby-plugin-sass": "^6.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "nanoid": "^5.1.16",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-awesome-reveal": "^4.3.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "react-github-btn": "^1.4.0",
    "react-scroll": "^1.9.3",
    "react-tilt": "^1.0.2",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cwhite911/cwhite911.github.io"
  },
  "bugs": {
    "url": "https://github.com/cwhite911/cwhite911.github.io/issues"
  },
  "lint-staged": {
    "*.{js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "overrides": {
    "sharp": "^0.33.5"
  }
}
